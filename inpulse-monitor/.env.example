# Serviço de Monitoramento Inpulse
# Variáveis de ambiente para o sistema de saúde e erros

# Supabase
SUPABASE_URL=https://mqkqfpbaxnjtadinctek.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# Configurações do Monitor
MONITOR_INTERVAL_MS=1000
HEALTH_CHECK_INTERVAL_MS=5000
MAX_ERRORS_PER_BATCH=50

# Caminhos para monitorar
ADMIN_PATH=../inpulse-admin
WEBSITE_PATH=../Inpulse_website

# Ambiente
NODE_ENV=production
LOG_LEVEL=info
